<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<!--
    카테고리 조회 MyBatis SQL
    → 단순한 조회이지만 CQRS 원칙에 따라 MyBatis로 처리한다.
    → map-underscore-to-camel-case: true 설정으로 display_order → displayOrder 자동 매핑
-->
<mapper namespace="com.mirae.hair.domain.product.query.CategoryQueryMapper">

    <!--
        전체 카테고리 목록 조회 (표시 순서대로)
        → 상품 등록/수정 화면의 카테고리 드롭다운에 사용된다.
        → displayOrder ASC로 정렬하여 순서대로 표시한다.
    -->
    <select id="selectCategoryList" resultType="com.mirae.hair.domain.product.dto.CategoryDto">
        SELECT id,
               name,
               display_order
        FROM categories
        ORDER BY display_order ASC
    </select>

</mapper>
